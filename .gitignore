# Important
.venv
vox1_test_wav
.idea
.vscode
.env*
ENV/
env/
*.iml
.mypy_cache/
.ruff_cache/
.pyright/

# Model Files - Ignore contents but keep directories
pretrained_models/whisper-small/*
!pretrained_models/whisper-small/.gitkeep

pretrained_models/ggml-whispersmall-multilingual/*
!pretrained_models/ggml-whispersmall-multilingual/.gitkeep

# Quantization
# 1. GGML Models contents ignored
quantization/ggml-whispersmall-multilingual/**/*
!quantization/ggml-whispersmall-multilingual/**/.gitkeep

# 2. Exports contents ignored
quantization/exports/ecapa/*
!quantization/exports/ecapa/.gitkeep
quantization/exports/whisper/*
!quantization/exports/whisper/.gitkeep

# 3. Scripts and structure tracked
# We ignore everything in quantization first, then whitelist what we want
quantization/*
!quantization/.gitkeep
!quantization/scripts/
!quantization/ggml-whispersmall-multilingual/
!quantization/exports/

# ===== Python bytecode / cache =====
__pycache__/
*.py[cod]
*$py.class

